        json.dump(rules, f, ensure_ascii=False, indent=2)

def load_llm_cache():
    if os.path.exists(LLM_CACHE_FILE):
        with open(LLM_CACHE_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
