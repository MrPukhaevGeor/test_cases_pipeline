            desc = re.sub(r'\*\*.*?\*\*', '', desc).strip()
            desc = desc.replace('\n', ' ').replace('"', "'")

            issue_entries.append(f"""      {{
        "type": "{title.split()[0] if title else 'Issue'}",
        "line": {line_num},
        "description": "{desc[:100]}"
      }}""")

        solve_script += ",\n".join(issue_entries)
        solve_script += """
    ]
  }
}
EOF
"""
        return solve_script

