        print(f"📦 Найдено кейсов: {len(cases)}")

        for case in cases:
            try:
                self.convert_case(case)
            except Exception as e:
                print(f"  ❌ Ошибка в {case.name}: {e}")
                import traceback
                traceback.print_exc()

        print(f"\n🎉 Конвертация завершена! Кейсы в: {OUTPUT_BASE}")

if __name__ == "__main__":
    converter = LegacyToBkasConverter()
    converter.run()
