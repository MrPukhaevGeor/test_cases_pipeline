        self.template_counter = 0

    def extract_language(self, context_text: str) -> str:
        """Определяет язык программирования по коду"""
        if 'import asyncio' in context_text or 'def ' in context_text or 'import decimal' in context_text:
            return 'python'
        elif 'function ' in context_text or 'const ' in context_text or 'async function' in context_text:
            return 'javascript'
        elif 'pub fn ' in context_text or '-> Option<' in context_text:
            return 'rust'
        elif 'public class' in context_text or 'public static' in context_text:
            return 'java'
        elif 'func ' in context_text and 'package ' in context_text:
            return 'go'
        return 'python'  # default

    def get_main_filename(self, language: str) -> str:
        """Возвращает имя файла по языку"""
        extensions = {
            'python': 'main.py',
            'javascript': 'main.js',
            'rust': 'main.rs',
            'java': 'Main.java',
            'go': 'main.go'
        }
        return extensions.get(language, 'main.txt')

    def parse_yaml_metadata(self, yaml_path: Path) -> Dict[str, Any]:
        """Парсит case.yaml"""
        if not yaml_path.exists():
            return {}
        try:
            with open(yaml_path, 'r', encoding='utf-8') as f:
                return yaml.safe_load(f) or {}
        except Exception:
            return {}

    def extract_json_from_answer(self, answer_path: Path) -> Optional[Dict]:
        """Извлекает JSON из эталонного ответа (если есть)"""
        if not answer_path.exists():
            return None

        content = answer_path.read_text(encoding='utf-8-sig')

        # Ищем JSON в тексте
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            try:
                return json.loads(json_match.group())
            except json.JSONDecodeError:
                pass
        return None

    def clean_json_keys(self, data: Any) -> Any:
        """Удаляет trailing spaces из ключей JSON"""
        if isinstance(data, dict):
            return {k.strip(): self.clean_json_keys(v) for k, v in data.items()}
        elif isinstance(data, list):
            return [self.clean_json_keys(item) for item in data]
        return data

    def generate_instruction(self, task_path: Path, yaml_data: Dict) -> str:
        """Генерирует instruction.md"""
        if not task_path.exists():
            return "# Task Description\n\nSee task.toml for details."

        content = task_path.read_text(encoding='utf-8-sig')

        # Если есть системный промпт в YAML, используем его
        if 'instruction' in yaml_data:
            instr = yaml_data['instruction']
            if isinstance(instr, str):
                # Очищаем от экранирования
                instr = instr.replace('\\n', '\n').replace('\\"', '"')
                return f"# Task Instruction\n\n{instr}"

        # Иначе берем из файла
        lines = content.strip().split('\n')
        clean_lines = []
        for line in lines:
            # Убираем маркеры [System], [User]
            if line.startswith('[') and ']' in line:
                continue
            clean_lines.append(line)

        return "\n".join(clean_lines)

    def generate_dockerfile(self, language: str, main_file: str) -> str:
        """Генерирует Dockerfile"""
        if language == 'python':
            return f"""FROM python:3.10-slim
WORKDIR /app
COPY repo/{main_file} .
RUN pip install --no-cache-dir pytest
RUN mkdir -p /logs/verifier
"""
        elif language == 'javascript':
            return f"""FROM python:3.10-slim
WORKDIR /app
COPY repo/{main_file} .
RUN pip install --no-cache-dir pytest
RUN mkdir -p /logs/verifier
