        issues = re.findall(r'(\d+)\.\s+\*\*(.+?)\*\*[:\s]+(.+?)(?=\d+\.|$)', content, re.DOTALL)

        issue_entries = []
        for line_num, title, desc in issues:
            # Очищаем текст
