        test_sh_path.write_text(test_sh, encoding='utf-8')
        os.chmod(test_sh_path, 0o755)

        # 6. Генерируем task.toml
        toml_content = self.generate_task_toml(case_name, yaml_data, language)
        (out_path / "task.toml").write_text(toml_content, encoding='utf-8')

        print(f"  ✅ Готово: {out_path}")

    def run(self):
        """Запускает конвертацию всех кейсов"""
        if not SOURCE_BASE.exists():
            print(f"❌ Папка {SOURCE_BASE} не найдена")
            return

        # Создаем выходную папку
        OUTPUT_BASE.mkdir(exist_ok=True)

        # Находим все кейсы
        cases = sorted([d for d in SOURCE_BASE.iterdir() if d.is_dir() and 'case' in d.name])
        print(f"📦 Найдено кейсов: {len(cases)}")

        for case in cases:
            try:
                self.convert_case(case)
            except Exception as e:
                print(f"  ❌ Ошибка в {case.name}: {e}")
                import traceback
                traceback.print_exc()

        print(f"\n🎉 Конвертация завершена! Кейсы в: {OUTPUT_BASE}")

