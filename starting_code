import os
import json
import pandas as pd
from difflib import SequenceMatcher

# Настройки
ARCHIVE_FOLDER = "test_cases"                  # папка с распакованным архивом
EXCEL_FILE = "table.xlsx"                      # Excel-файл с таблицей
EXCEL_SHEET = "Sheet1"                          # название листа в Excel

# Правила для определения роли (веса 3/2/1, где 3 самый сильный и весомый)
ROLE_KEYWORDS = {
    "Разработчик": {
        "алгоритм": 3, "сортировка": 3, "перепиши": 3,
        "функцию": 2, "класс": 2, "оптимизируй": 2, "реализуй": 2,
        "код": 1, "напиши": 1, "программа": 1
    },
    "Аналитик": {
        "sql": 3, "json": 3, "витрина": 3,
        "запрос": 2, "отчёт": 2, "дашборд": 2, "выборка": 2,
        "данные": 1, "отчет": 1, "анализ": 1
    },
    "Тестировщик": {
        "юнит-тест": 3, "баг": 3, "тест-кейс": 3,
        "проверь": 2, "отладка": 2, "дебаг": 2,
        "тест": 1, "найди": 1, "ошибку": 1
    }
}

# Файл для сохранения изученных правил
LEARNING_FILE = "learned_rules.json"

def load_learned_rules():
    """Загружает изученные правила из файла"""
    if os.path.exists(LEARNING_FILE):
        with open(LEARNING_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {"keywords": {}}

def save_learned_rules(rules):
    """Сохраняет изученные правила в файл"""
    with open(LEARNING_FILE, 'w', encoding='utf-8') as f:
        json.dump(rules, f, ensure_ascii=False, indent=2)

def determine_role(description, learned_rules):
    """Определяет роль по ключевым словам (с весами)"""
    if not description:
        return None
    
    desc_lower = description.lower()
    
    # Собираем все правила (базовые + изученные)
    all_keywords = {}
    for role, keywords in ROLE_KEYWORDS.items():
        all_keywords[role] = keywords.copy()
    
    # Добавляем изученные правила
    learned = learned_rules.get("keywords", {})
    for keyword, role in learned.items():
        if role not in all_keywords:
            all_keywords[role] = {}
        all_keywords[role][keyword] = 2  # вес для изученных слов 
        ??????????????????????????????????????????????
    
    # Подсчёт очков
    scores = {}
    for role, keywords in all_keywords.items():
        score = 0
        matched = []
        for word, weight in keywords.items():
            if word in desc_lower:
                score += weight
                matched.append(f"{word}({weight})")
        if score > 0:
            scores[role] = {"score": score, "matches": matched}
    
    if not scores:
        return None
    
    # Выбираем роль с максимальным счётом
    best_role = max(scores, key=lambda r: scores[r]["score"])
    return best_role

def find_similar_row(df, description, threshold=0.5):
    """Ищет похожую строку в таблице по колонке 'Описание задачи'"""
    if "Описание задачи" not in df.columns:
        print("⚠️ В таблице нет колонки 'Описание задачи'")
        return None
    
    best_match = None
    best_ratio = 0
    
    for idx, row in df.iterrows():
        task_desc = str(row["Описание задачи"]) if pd.notna(row["Описание задачи"]) else ""
        if not task_desc:
            continue
        
        ratio = SequenceMatcher(None, description.lower(), task_desc.lower()).ratio()
        if ratio > best_ratio and ratio > threshold:
            best_ratio = ratio
            best_match = idx
    
    return best_match, best_ratio

def read_description_from_folder(folder_path):
    """Читает описание задачи из папки (ищет в 01_... или .txt)"""
    for item in os.listdir(folder_path):
        item_path = os.path.join(folder_path, item)
        # Ищем папку, начинающуюся с 01_
        if os.path.isdir(item_path) and item.startswith("01_"):
            for file in os.listdir(item_path):
                if file.endswith(".txt"):
                    with open(os.path.join(item_path, file), 'r', encoding='utf-8') as f:
                        return f.read().strip()
    return None

def add_basket_to_cell(existing, new_basket):
    """Добавляет номер корзины в ячейку (через запятую)"""
    if pd.isna(existing) or existing == "":
        return new_basket
    existing_str = str(existing)
    if new_basket in existing_str:
        return existing_str
    return f"{existing_str}, {new_basket}"

def main():
    df = pd.read_excel(EXCEL_FILE, sheet_name=EXCEL_SHEET)
    print(f"Загружена таблица: {len(df)} строк")
    
    # Загружаем изученные правила
    learned_rules = load_learned_rules()
    print(f"Загружено изученных правил: {len(learned_rules.get('keywords', {}))}")
    
    # Получаем список всех папок в архиве
    folders = [f for f in os.listdir(ARCHIVE_FOLDER) if os.path.isdir(os.path.join(ARCHIVE_FOLDER, f))]
    print(f"Найдено папок (кейсов): {len(folders)}")
    
    # Статистика
    stats = {"auto": 0, "manual": 0, "new_row": 0}
    
    # Обрабатываем каждую папку
    for i, folder_name in enumerate(folders, 1):
        folder_path = os.path.join(ARCHIVE_FOLDER, folder_name)
        print(f"\n[{i}/{len(folders)}] Папка: {folder_name}")
        
        # Читаем описание
        description = read_description_from_folder(folder_path)
        if not description:
            print(f"Не найдено описание задачи. Пропускаем.")
            stats["skipped"] += 1
            continue
        print(f"Описание: {description[:100]}...")
        
        # Определяем роль автоматически
        role = determine_role(description, learned_rules)
        if role:
            print(f"Автоопределение: {role}")
            stats["auto"] += 1
        else:
            print(f"Не удалось определить роль автоматически")
            # Спрашиваем у пользователя
            print("\nВарианты ролей:")
            print("      1 - Разработчик")
            print("      2 - Аналитик")
            print("      3 - Тестировщик")

            while True:
                choice = input("Твой выбор (1/2/3): ").strip()
                if choice == '1':
                    role = "Разработчик"
                    break
                elif choice == '2':
                    role = "Аналитик"
                    break
                elif choice == '3':
                    role = "Тестировщик"
                    break

            # Запоминаем новое правило
            ??????????????????????????????????????????????????????????
            stats["manual"] += 1
        
        # Ищем похожую строку в таблице
        match_idx, match_ratio = find_similar_row(df, description)
        
        if match_idx is not None:
            print(f"Найдена похожая строка (совпадение {match_ratio:.0%})")
            row_idx = match_idx
        else:
            print(f"Похожих строк не найдено. Создаём новую строку.")
            new_row = {
                "Описание задачи": f"New {description[:100]}",
                "Роли для сценария": role,
                "Корзины": folder_name
            }
            # Добавляем только существующие колонки
            for col in df.columns:
                if col not in new_row:
                    new_row[col] = None
            df = pd.concat([df, pd.DataFrame([new_row])], ignore_index=True)
            row_idx = len(df) - 1
            stats["new_row"] += 1
        
        # Обновляем колонку "Корзины"
        current_baskets = df.at[row_idx, "Корзины"] if "Корзины" in df.columns else ""
        df.at[row_idx, "Корзины"] = add_basket_to_cell(current_baskets, folder_name)
        
        # Обновляем колонку "Роли для сценария" (если пусто)
        if "Роли для сценария" in df.columns:
            current_role = df.at[row_idx, "Роли для сценария"]
            if pd.isna(current_role) or current_role == "":
                df.at[row_idx, "Роли для сценария"] = role
        
        # Сохраняем после каждого кейса
        df.to_excel(EXCEL_FILE, sheet_name=EXCEL_SHEET, index=False)
        print(f" Сохранено в строку {row_idx + 1}")
    
    print(" СТАТИСТИКА ОБРАБОТКИ:")
    print(f"Автоопределено ролей: {stats['auto']}")
    print(f"Вручную определено ролей: {stats['manual']}")
    print(f"Создано новых строк: {stats['new_row']}")
    print(f"Пропущено: {stats['skipped']}")
    print(f"Всего обработано: {i}")
    print(f"Таблица сохранена в {EXCEL_FILE}")
    print(f"Изученные правила сохранены в {LEARNING_FILE}")

if __name__ == "__main__":
    main()
