# local_check.py - Автономная проверка БЕЗ pytest и Docker
import os
import sys
import json

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
LOGS_DIR = os.path.join(BASE_DIR, "logs", "verifier")
REWARD_FILE = os.path.join(LOGS_DIR, "reward.txt")
OUTPUT_FILE = os.path.join(BASE_DIR, "agent_output.json")

def validate_json_structure(data):
    """Pass-to-Pass: Проверка формата"""
    assert isinstance(data, dict), "Ответ должен быть словарем"
    assert "vulnerabilities" in data, "Нет ключа vulnerabilities"
    assert isinstance(data["vulnerabilities"], list), "vulnerabilities должен быть списком"
    assert "summary" in data, "Нет ключа summary"
    return True

def validate_content(data):
    """Fail-to-Pass: Проверка содержания"""
    vulns = data.get("vulnerabilities", [])
    types = [v.get("type") for v in vulns]
    
    errors = []
    if "XSS" not in types: errors.append("Не найдена XSS")
    if "EvalUsage" not in types: errors.append("Не найден EvalUsage")
    if "FetchError" not in types and not any("status" in str(v).lower() for v in vulns): 
        errors.append("Не найдена ошибка Fetch/Status")
        
    if errors:
        raise AssertionError(f"Критические уязвимости не найдены: {', '.join(errors)}")
    return True

def run_scenario(name, apply_solution=False):
    print(f"\n{'='*50}")
    print(f"🧪 Сценарий: {name}")
    print(f"{'='*50}")
    
    # Очистка
    if os.path.exists(OUTPUT_FILE):
        os.remove(OUTPUT_FILE)
    
    # Применение решения (эмуляция solve.sh)
    if apply_solution:
        print("⚙️ Применяем эталонное решение...")
        solution_data = {
            "vulnerabilities": [
                {"type": "XSS", "line": 6, "description": "innerHTML"},
                {"type": "FetchError", "line": 11, "description": "no status check"},
                {"type": "MemoryLeak", "line": 18, "description": "no removeEventListener"},
                {"type": "EvalUsage", "line": 24, "description": "eval()"}
            ],
            "summary": "Critical issues found."
        }
        with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
            json.dump(solution_data, f, ensure_ascii=False, indent=2)
        print("✅ Эталонный JSON создан.")
    else:
        print("🚫 Решение не применено (база).")

    # Проверка
    reward = 0
    try:
        if not os.path.exists(OUTPUT_FILE):
            raise FileNotFoundError("Файл ответа отсутствует")
            
        with open(OUTPUT_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            
        validate_json_structure(data)
        validate_content(data)
        
        reward = 1
        print("✅ Тесты пройдены успешно.")
        
    except Exception as e:
        print(f"❌ Тесты провалены: {e}")
        reward = 0

    # Запись результата
    os.makedirs(LOGS_DIR, exist_ok=True)
    with open(REWARD_FILE, "w") as f:
        f.write(str(reward))
    print(f
